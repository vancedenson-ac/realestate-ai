# realtrust ai — FastAPI API (Python 3.12, uvicorn)
FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src/ ./src/

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir .

# Ensure the app can import realtrust_api (fallback if wheel layout differs)
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/src
EXPOSE 8000
CMD ["python", "-m", "uvicorn", "realtrust_api.main:app", "--host", "0.0.0.0", "--port", "8000"]
